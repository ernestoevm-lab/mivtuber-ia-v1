# Server
PORT=8787

# LLM provider
LLM_PROVIDER=lmstudio

# LM Studio local OpenAI-compatible server
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_API_MODE=openai
LM_STUDIO_MODEL=your_lm_studio_model_name_here
LLM_MAX_TOKENS=512
LLM_STORE_REASONING=true
LLM_REASONING_MAX_CHARS=8000
LLM_REASONING_REPAIR_ENABLED=true
LLM_REASONING_REPAIR_MAX_TOKENS=512
LLM_REASONING_REPAIR_TEMPERATURE=0.1
LM_STUDIO_REASONING_EFFORT=low
LLM_SMALL_MODEL_COMPACT_PROMPT=true
LLM_SMALL_MODEL_HISTORY_LIMIT=6
LLM_SMALL_MODEL_MEMORY_LIMIT=5
LLM_SMALL_MODEL_EXAMPLE_LIMIT=4
LLM_SMALL_MODEL_MAX_TOKENS=384
LLM_SMALL_MODEL_TEMPERATURE=0.65

# Optional LM Studio load flags used by Start-Luma option 2/3.
# LM_STUDIO_GPU_OFFLOAD=max asks LM Studio for maximum GPU offload; useful for small models, but watch VRAM with larger models or games.
LM_STUDIO_GPU_OFFLOAD=
LM_STUDIO_CONTEXT_LENGTH=

# Optional Ollama fallback
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=your_ollama_model_here
OLLAMA_FALLBACK_MODEL=your_ollama_fallback_model_here

# Python
PYTHON_BIN=python

# Twitch read-only chat integration
TWITCH_ENABLED=true
TWITCH_CHANNEL=your_twitch_channel_here
TWITCH_BOT_USERNAME=your_bot_username_here
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_OAUTH_TOKEN=your_twitch_oauth_token_here

# Kokoro TTS
# Default remains browser fallback. Enable Kokoro only after local setup.
TTS_BACKEND=browser
TTS_EXPERIMENTAL_LOCAL=false
TTS_STREAMING_ENABLED=false
KOKORO_SPEED=0.95
KOKORO_LANGUAGE=es
KOKORO_LANG=
# Common ONNX voices: ef_dora (ES female), jf_alpha/jf_gongitsune/jf_nezumi/jf_tebukuro (JP female style).
KOKORO_VOICE=ef_dora
KOKORO_PYTHON=
KOKORO_MODEL_PATH=
KOKORO_VOICES_PATH=
KOKORO_HF_HOME=.local/huggingface
