    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "three": "^0.181.2",
    "vite": "^7.2.7",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
