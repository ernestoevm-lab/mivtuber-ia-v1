{
  "name": "local-vtuber-ai",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc -p tsconfig.json && vite build",
    "tauri:prepare-sidecars": "node scripts/prepare-tauri-sidecars.mjs",
    "lmstudio:start": "lms server start && lms load gemma-4-26b-a4b-it",
    "lmstudio:stop": "lms server stop",
    "stop": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File Stop-Luma.ps1 -Quiet",
    "preview": "node dist-server/server/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "tauri": "tauri",
    "app:dev": "tauri dev",
    "app:build": "tauri build",
    "qa:tikfinity-autonomy": "node --import tsx scripts/qa-tikfinity-autonomy.mjs",
    "qa:structured": "node --import tsx scripts/qa-structured-response.mjs",
